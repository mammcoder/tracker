<Window x:Class="HabitTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Habit Tracker" 
        Width="320" 
        Height="Auto"
        SizeToContent="Height"
        MaxHeight="600"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        StateChanged="Window_StateChanged">

    <Border Background="{DynamicResource BackgroundBrush}"
            CornerRadius="14"
            BorderThickness="0"
            PreviewMouseLeftButtonDown="Border_PreviewMouseLeftButtonDown">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0">
            <ItemsControl ItemsSource="{Binding Habits}" Margin="8,8,8,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBrush}"
                                BorderThickness="0"
                                CornerRadius="8"
                                Padding="12,10"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="{Binding Name, Mode=OneWay}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock FontSize="13"
                                               Foreground="{DynamicResource SubTextBrush}">
                                        <Run Text="{Binding TotalDays, Mode=OneWay}"/>
                                        <Run Text=" с "/>
                                        <Run Text="{Binding StartDate, StringFormat='dd.MM.yyyy', Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>

                                <Grid Grid.Row="2">
                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" 
                                                 Minimum="0" 
                                                 Maximum="100"
                                                 Height="20"
                                                 Background="{DynamicResource FutureBrush}"
                                                 Foreground="{DynamicResource AccentBrush}"
                                                 BorderThickness="0"/>
                                    <TextBlock FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,-2,0,0">
                                        <Run Text="{Binding ProgressPercent, StringFormat='{}{0:F0}%', Mode=OneWay}"/>
                                    </TextBlock>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Border>
</Window>
